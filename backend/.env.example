DATABASE_URL=postgresql+asyncpg://user:password@host/database?sslmode=require
CORS_ORIGINS=http://localhost:3000

# Phase III: AI Chatbot (Google Gemini via OpenAI-compatible endpoint)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Phase IV: Kubernetes Deployment Notes
# When deploying to Minikube via Helm, these values are passed via:
#   helm install todo-app ./helm/todo-app \
#     --set backend.env.DATABASE_URL="<your-neon-url>" \
#     --set backend.env.GEMINI_API_KEY="<your-key>" \
#     --set frontend.env.NEXT_PUBLIC_API_URL="http://<minikube-ip>:30001"
# See specs/004-phase4-k8s-deployment/quickstart.md for full instructions.
